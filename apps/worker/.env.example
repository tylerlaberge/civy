# Civy worker configuration. Copy this file to .env and adjust.
# All variables are validated at boot (src/config/env.validation.ts); an invalid
# value stops the process from starting.

# Redis connection URL — the BullMQ queue backing store. In the devcontainer,
# Redis runs as a sibling compose service; locally, `docker run -p 6379:6379 redis`.
REDIS_URL=redis://localhost:6379

# Filesystem path to the SQLite database. The API and worker must share one
# filesystem (WAL mode lets API reads and worker writes coexist).
DATABASE_PATH=./data/civy.sqlite
