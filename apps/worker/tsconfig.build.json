{
  // Used by `nest build`: compile only src/ (no test/vitest files), rooted at
  // src/ so the entrypoint emits to dist/main.js (matching the `start` script).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src"
  },
  "include": ["src"],
  // TypeScript's glob exclude does not expand `{test,spec}` braces, so the two
  // suffixes are listed separately to keep test files out of dist/.
  "exclude": ["dist", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
