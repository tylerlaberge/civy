{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Astro + React use bundler resolution and JSX, which diverge from the
    // NodeNext defaults in the base config; override only what Astro requires.
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["astro/client", "@testing-library/jest-dom"],
    // Dev/typecheck consume @civy/types straight from source (no build step);
    // the workspace dependency still gives moon the build-graph edge. Imports
    // are type-only, so nothing resolves this at runtime.
    "paths": {
      "@civy/types": ["../../packages/types/src/index"]
    }
  },
  "include": ["src", "astro.config.mjs", "vitest.config.ts", "vitest.setup.ts"],
  "exclude": ["dist"]
}
