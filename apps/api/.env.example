# Civy API configuration. Copy this file to .env and adjust.
# All variables are validated at boot (src/config/env.validation.ts); an invalid
# value stops the server from starting.

# Port the HTTP server listens on.
PORT=3000

# Filesystem path to the SQLite database. The API and worker must share one
# filesystem (WAL mode lets API reads and worker writes coexist).
DATABASE_PATH=./data/civy.sqlite

# Origin allowed by CORS — the web app (apps/web). Astro's dev server defaults
# to port 4321.
CORS_ORIGIN=http://localhost:4321
